rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID
    //   - displayName: string (required, max 50 chars) - User's display name
    //   - photoURL: string (optional, max 1000 chars) - Profile picture URL
    //   - bio: string (optional, max 150 chars) - User's biography
    //   - followersCount: number (required) - Number of followers
    //   - followingCount: number (required) - Number of users followed
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - authorId: string (required, immutable) - Author's UID
    //   - authorName: string (required, max 50 chars) - Author's display name
    //   - authorPhoto: string (optional, max 1000 chars) - Author's profile picture URL
    //   - imageUrl: string (optional, max 1000 chars) - Primary image URL
    //   - videoUrl: string (optional, max 1000 chars) - Primary video URL
    //   - mediaType: string (required) - 'image' or 'video'
    //   - mediaUrls: list (required) - List of {url, type} objects
    //   - caption: string (optional, max 2200 chars) - Post caption
    //   - tags: list (optional) - Hashtags extracted from caption
    //   - mentions: list (optional) - User mentions extracted from caption
    //   - likesCount: number (required) - Number of likes
    //   - commentsCount: number (required) - Number of comments
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: stories
    // Document ID: {storyId}
    // Fields:
    //   - authorId: string (required, immutable) - Author's UID
    //   - authorName: string (required, max 50 chars) - Author's display name
    //   - authorPhoto: string (optional, max 1000 chars) - Author's profile picture URL
    //   - imageUrl: string (optional, max 1000 chars) - Story image URL
    //   - videoUrl: string (optional, max 1000 chars) - Story video URL
    //   - mediaType: string (required) - 'image' or 'video'
    //   - createdAt: timestamp (required, immutable) - Creation time
    //   - expiresAt: timestamp (required) - Expiration time
    //   - viewsCount: number (optional) - Number of views
    //   - viewers: list (optional) - List of viewer UIDs
    //   - likesCount: number (optional) - Number of likes
    //   - likedBy: list (optional) - List of user UIDs who liked the story
    //
    // Collection: storyLikes
    // Document ID: {storyId}_{userId}
    // Fields:
    //   - storyId: string (required, immutable) - Liked story ID
    //   - userId: string (required, immutable) - Liking user ID
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: likes
    // Document ID: {postId}_{userId}
    // Fields:
    //   - postId: string (required, immutable) - Liked post ID
    //   - userId: string (required, immutable) - Liking user ID
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: follows
    // Document ID: {followerId}_{followingId}
    // Fields:
    //   - followerId: string (required, immutable) - Follower user ID
    //   - followingId: string (required, immutable) - Followed user ID
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - participants: list (required, size 2) - UIDs of participants
    //   - lastMessage: string (optional, max 1000 chars) - Last message text
    //   - lastMessageTime: timestamp (optional) - Last message time
    //   - updatedAt: timestamp (required) - Last update time
    //
    // Collection: messages (subcollection of chats)
    // Document ID: {messageId}
    // Fields:
    //   - chatId: string (required, immutable) - Chat ID
    //   - senderId: string (required, immutable) - Sender UID
    //   - text: string (required, max 1000 chars) - Message text
    //   - attachmentUrl: string (optional, max 1000 chars) - Media attachment URL
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: comments
    // Document ID: {commentId}
    // Fields:
    //   - postId: string (required, immutable) - Post ID
    //   - authorId: string (required, immutable) - Author UID
    //   - authorName: string (required, max 50 chars) - Author display name
    //   - authorPhoto: string (optional, max 1000 chars) - Author profile picture URL
    //   - text: string (required, max 500 chars) - Comment text
    //   - likesCount: number (optional) - Number of likes
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: commentLikes
    // Document ID: {commentId}_{userId}
    // Fields:
    //   - commentId: string (required, immutable) - Liked comment ID
    //   - postId: string (required, immutable) - Post ID
    //   - userId: string (required, immutable) - Liking user ID
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
         (request.auth.token.get('email', '') == "nishantmanish4@gmail.com" && request.auth.token.get('email_verified', false) == true));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isUnchanged(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isValidOptionalNumber(field) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == null || 
             (request.resource.data[field] is number && request.resource.data[field] >= 0);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'username', 'displayName', 'photoURL', 'bio', 'followersCount', 'followingCount', 'createdAt', 'role', 'email']) &&
             hasRequiredFields(['uid', 'username', 'displayName']) &&
             validStringLength('uid', 1, 128) &&
             validStringLength('username', 3, 30) &&
             validStringLength('displayName', 1, 100) &&
             isValidOptionalString('photoURL', 0, 2000) &&
             isValidOptionalString('bio', 0, 500) &&
             isValidOptionalNumber('followersCount') &&
             isValidOptionalNumber('followingCount') &&
             (request.resource.data.get('createdAt', null) == null || request.resource.data.createdAt is timestamp) &&
             (request.resource.data.get('role', 'user') in ['user', 'admin']);
    }

    function isValidPost() {
      return hasOnlyAllowedFields(['authorId', 'authorName', 'authorPhoto', 'imageUrl', 'videoUrl', 'mediaType', 'mediaUrls', 'caption', 'tags', 'mentions', 'likesCount', 'commentsCount', 'createdAt']) &&
             hasRequiredFields(['authorId', 'authorName', 'mediaType', 'mediaUrls', 'createdAt']) &&
             validStringLength('authorId', 1, 128) &&
             validStringLength('authorName', 1, 100) &&
             isValidOptionalString('authorPhoto', 0, 2000) &&
             isValidOptionalString('imageUrl', 0, 2000) &&
             isValidOptionalString('videoUrl', 0, 2000) &&
             request.resource.data.mediaType in ['image', 'video'] &&
             request.resource.data.mediaUrls is list &&
             request.resource.data.mediaUrls.size() > 0 &&
             request.resource.data.mediaUrls.size() <= 10 &&
             isValidOptionalString('caption', 0, 2200) &&
             (!('tags' in request.resource.data) || request.resource.data.tags is list) &&
             (!('mentions' in request.resource.data) || request.resource.data.mentions is list) &&
             isValidOptionalNumber('likesCount') &&
             isValidOptionalNumber('commentsCount') &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidLike() {
      return hasOnlyAllowedFields(['postId', 'userId', 'createdAt']) &&
             hasRequiredFields(['postId', 'userId', 'createdAt']) &&
             validStringLength('postId', 1, 128) &&
             validStringLength('userId', 1, 128) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidFollow() {
      return hasOnlyAllowedFields(['followerId', 'followingId', 'createdAt']) &&
             hasRequiredFields(['followerId', 'followingId', 'createdAt']) &&
             validStringLength('followerId', 1, 128) &&
             validStringLength('followingId', 1, 128) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidComment() {
      return hasOnlyAllowedFields(['postId', 'authorId', 'authorName', 'authorPhoto', 'text', 'likesCount', 'createdAt']) &&
             hasRequiredFields(['postId', 'authorId', 'authorName', 'text', 'createdAt']) &&
             validStringLength('postId', 1, 128) &&
             validStringLength('authorId', 1, 128) &&
             validStringLength('authorName', 1, 100) &&
             isValidOptionalString('authorPhoto', 0, 2000) &&
             validStringLength('text', 1, 500) &&
             isValidOptionalNumber('likesCount') &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidCommentLike() {
      return hasOnlyAllowedFields(['commentId', 'postId', 'userId', 'createdAt']) &&
             hasRequiredFields(['commentId', 'postId', 'userId', 'createdAt']) &&
             validStringLength('commentId', 1, 128) &&
             validStringLength('postId', 1, 128) &&
             validStringLength('userId', 1, 128) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidNotification() {
      return hasOnlyAllowedFields(['userId', 'type', 'senderId', 'senderName', 'senderPhoto', 'postId', 'chatId', 'storyId', 'commentId', 'contentPreview', 'read', 'createdAt']) &&
             hasRequiredFields(['userId', 'type', 'senderId', 'senderName', 'read', 'createdAt']) &&
             validStringLength('userId', 1, 128) &&
             validStringLength('type', 1, 20) &&
             validStringLength('senderId', 1, 128) &&
             validStringLength('senderName', 1, 100) &&
             isValidOptionalString('senderPhoto', 0, 2000) &&
             isValidOptionalString('postId', 0, 128) &&
             isValidOptionalString('chatId', 0, 128) &&
             isValidOptionalString('storyId', 0, 128) &&
             isValidOptionalString('commentId', 0, 128) &&
             isValidOptionalString('contentPreview', 0, 1000) &&
             request.resource.data.read is bool &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidSavedPost() {
      return hasOnlyAllowedFields(['userId', 'postId', 'createdAt']) &&
             hasRequiredFields(['userId', 'postId', 'createdAt']) &&
             validStringLength('userId', 1, 128) &&
             validStringLength('postId', 1, 128) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidStory() {
      return hasOnlyAllowedFields(['authorId', 'authorName', 'authorPhoto', 'imageUrl', 'videoUrl', 'mediaType', 'createdAt', 'expiresAt', 'viewsCount', 'viewers', 'likesCount', 'likedBy']) &&
             hasRequiredFields(['authorId', 'authorName', 'mediaType', 'createdAt', 'expiresAt']) &&
             validStringLength('authorId', 1, 128) &&
             validStringLength('authorName', 1, 100) &&
             isValidOptionalString('authorPhoto', 0, 2000) &&
             isValidOptionalString('imageUrl', 0, 2000) &&
             isValidOptionalString('videoUrl', 0, 2000) &&
             request.resource.data.mediaType in ['image', 'video'] &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.expiresAt is timestamp &&
             isValidOptionalNumber('viewsCount') &&
             (!('viewers' in request.resource.data) || request.resource.data.viewers is list) &&
             isValidOptionalNumber('likesCount') &&
             (!('likedBy' in request.resource.data) || request.resource.data.likedBy is list);
    }

    function isValidStoryLike() {
      return hasOnlyAllowedFields(['storyId', 'userId', 'createdAt']) &&
             hasRequiredFields(['storyId', 'userId', 'createdAt']) &&
             validStringLength('storyId', 1, 128) &&
             validStringLength('userId', 1, 128) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidHighlight() {
      return hasOnlyAllowedFields(['userId', 'label', 'imageUrl', 'mediaUrls', 'createdAt', 'viewsCount', 'viewers']) &&
             hasRequiredFields(['userId', 'label', 'imageUrl', 'mediaUrls', 'createdAt']) &&
             validStringLength('userId', 1, 128) &&
             validStringLength('label', 1, 50) &&
             validStringLength('imageUrl', 1, 2000) &&
             request.resource.data.mediaUrls is list &&
             request.resource.data.mediaUrls.size() <= 100 &&
             request.resource.data.createdAt is timestamp &&
             isValidOptionalNumber('viewsCount') &&
             (!('viewers' in request.resource.data) || request.resource.data.viewers is list);
    }

    function isValidChat() {
      return hasOnlyAllowedFields(['participants', 'lastMessage', 'lastMessageTime', 'lastMessageSenderId', 'updatedAt', 'readStatus', 'typingStatus']) &&
             hasRequiredFields(['participants', 'updatedAt']) &&
             request.resource.data.participants is list &&
             request.resource.data.participants.size() == 2 &&
             isValidOptionalString('lastMessage', 0, 1000) &&
             isValidOptionalString('lastMessageSenderId', 0, 128) &&
             (request.resource.data.lastMessageTime is timestamp || !('lastMessageTime' in request.resource.data)) &&
             (request.resource.data.readStatus is map || !('readStatus' in request.resource.data)) &&
             (request.resource.data.typingStatus is map || !('typingStatus' in request.resource.data)) &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidBlock() {
      return hasOnlyAllowedFields(['blockerId', 'blockedId', 'createdAt']) &&
             hasRequiredFields(['blockerId', 'blockedId', 'createdAt']) &&
             validStringLength('blockerId', 1, 128) &&
             validStringLength('blockedId', 1, 128) &&
             request.resource.data.createdAt is timestamp;
    }

    function isBlocked(blockerId, blockedId) {
      return exists(/databases/$(database)/documents/blocks/$(blockerId + '_' + blockedId));
    }

    function isEitherBlocked(userA, userB) {
      return isBlocked(userA, userB) || isBlocked(userB, userA);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged() && 
                    request.resource.data.followersCount == 0 && request.resource.data.followingCount == 0 &&
                    request.resource.data.get('role', 'user') == 'user';
      allow update: if isAuthenticated() && (
                      // Owner updating profile
                      (isOwner(userId) && isValidUser() && uidNotModified() && 
                       isUnchanged('createdAt') &&
                       isUnchanged('followersCount') &&
                       isUnchanged('followingCount') &&
                       isUnchanged('role'))
                      ||
                      // System/Users updating counts (Follow/Unfollow)
                      (hasOnlyAllowedFields(['uid', 'username', 'displayName', 'photoURL', 'bio', 'followersCount', 'followingCount', 'createdAt', 'role', 'email']) &&
                       areImmutableFieldsUnchanged(['uid', 'username', 'displayName', 'photoURL', 'bio', 'createdAt', 'role', 'email']) &&
                       (
                         // Update followersCount
                         (request.resource.data.get('followersCount', 0) != resource.data.get('followersCount', 0) &&
                          math.abs(request.resource.data.get('followersCount', 0) - resource.data.get('followersCount', 0)) == 1 &&
                          (
                            // Follow: count increased, follow doc must be created in this batch
                            (request.resource.data.get('followersCount', 0) > resource.data.get('followersCount', 0) &&
                             getAfter(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + userId)) != null) ||
                            // Unfollow: count decreased, follow doc must be deleted in this batch
                            (request.resource.data.get('followersCount', 0) < resource.data.get('followersCount', 0) &&
                             getAfter(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + userId)) == null)
                          )
                         ) ||
                         // Update followingCount (Owner only)
                         (isOwner(userId) && 
                          request.resource.data.get('followingCount', 0) != resource.data.get('followingCount', 0) &&
                          math.abs(request.resource.data.get('followingCount', 0) - resource.data.get('followingCount', 0)) == 1
                         )
                       )
                      )
                      ||
                      // Admin can update anything
                      isAdmin()
                    );
      allow delete: if isOwner(userId) || isAdmin();
    }

    function isValidMessage() {
      return hasOnlyAllowedFields(['chatId', 'senderId', 'text', 'attachmentUrl', 'sharedPostId', 'sharedPostSlideIndex', 'sharedPostPreviewUrl', 'sharedPostMediaType', 'sharedProfileId', 'sharedStoryId', 'sharedStoryPreviewUrl', 'sharedStoryMediaType', 'createdAt', 'editedAt', 'isEdited', 'deletedFor']) &&
             hasRequiredFields(['chatId', 'senderId', 'text', 'createdAt']) &&
             validStringLength('chatId', 1, 128) &&
             validStringLength('senderId', 1, 128) &&
             request.resource.data.text is string &&
             request.resource.data.text.size() <= 1000 &&
             (request.resource.data.text.size() > 0 || 
              ('attachmentUrl' in request.resource.data && request.resource.data.attachmentUrl.size() > 0) || 
              ('sharedPostId' in request.resource.data && request.resource.data.sharedPostId.size() > 0) ||
              ('sharedProfileId' in request.resource.data && request.resource.data.sharedProfileId.size() > 0) ||
              ('sharedStoryId' in request.resource.data && request.resource.data.sharedStoryId.size() > 0)) &&
             isValidOptionalString('attachmentUrl', 0, 2000) &&
             isValidOptionalString('sharedPostId', 0, 128) &&
             isValidOptionalNumber('sharedPostSlideIndex') &&
             isValidOptionalString('sharedPostPreviewUrl', 0, 2000) &&
             isValidOptionalString('sharedPostMediaType', 0, 20) &&
             isValidOptionalString('sharedProfileId', 0, 128) &&
             isValidOptionalString('sharedStoryId', 0, 128) &&
             isValidOptionalString('sharedStoryPreviewUrl', 0, 2000) &&
             isValidOptionalString('sharedStoryMediaType', 0, 20) &&
             request.resource.data.createdAt is timestamp &&
             (!('editedAt' in request.resource.data) || request.resource.data.editedAt is timestamp) &&
             (!('isEdited' in request.resource.data) || request.resource.data.isEdited is bool) &&
             (!('deletedFor' in request.resource.data) || request.resource.data.deletedFor is list);
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidPost() && 
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.likesCount == 0;
                    
      allow update: if isAuthenticated() && isValidPost() && (
                      // Owner updating caption
                      (request.resource.data.authorId == request.auth.uid &&
                       isUnchanged('authorId') &&
                       isUnchanged('authorName') &&
                       isUnchanged('authorPhoto') &&
                       isUnchanged('imageUrl') &&
                       isUnchanged('videoUrl') &&
                       isUnchanged('mediaType') &&
                       isUnchanged('mediaUrls') &&
                       isUnchanged('createdAt') &&
                       isUnchanged('likesCount') &&
                       isUnchanged('commentsCount'))
                      ||
                      // Anyone updating likesCount
                      (isUnchanged('authorId') &&
                       isUnchanged('authorName') &&
                       isUnchanged('authorPhoto') &&
                       isUnchanged('imageUrl') &&
                       isUnchanged('videoUrl') &&
                       isUnchanged('mediaType') &&
                       isUnchanged('mediaUrls') &&
                       isUnchanged('caption') &&
                       isUnchanged('tags') &&
                       isUnchanged('mentions') &&
                       isUnchanged('createdAt') &&
                       isUnchanged('commentsCount') &&
                       (request.resource.data.likesCount - resource.data.likesCount == 1 || resource.data.likesCount - request.resource.data.likesCount == 1) &&
                       (
                         (request.resource.data.likesCount > resource.data.likesCount &&
                          !exists(/databases/$(database)/documents/likes/$(postId + '_' + request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/likes/$(postId + '_' + request.auth.uid)) != null) ||
                         (request.resource.data.likesCount < resource.data.likesCount &&
                          exists(/databases/$(database)/documents/likes/$(postId + '_' + request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/likes/$(postId + '_' + request.auth.uid)) == null)
                       )
                      )
                      ||
                      // Anyone updating commentsCount
                      (isUnchanged('authorId') &&
                       isUnchanged('authorName') &&
                       isUnchanged('authorPhoto') &&
                       isUnchanged('imageUrl') &&
                       isUnchanged('videoUrl') &&
                       isUnchanged('mediaType') &&
                       isUnchanged('mediaUrls') &&
                       isUnchanged('caption') &&
                       isUnchanged('tags') &&
                       isUnchanged('mentions') &&
                       isUnchanged('createdAt') &&
                       isUnchanged('likesCount') &&
                       (request.resource.data.commentsCount - resource.data.commentsCount == 1 || resource.data.commentsCount - request.resource.data.commentsCount == 1)
                      )
                      ||
                      // Admin can update anything
                      isAdmin()
                    );
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidLike() &&
                    request.resource.data.userId == request.auth.uid &&
                    likeId == request.resource.data.postId + '_' + request.auth.uid;
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidFollow() &&
                    request.resource.data.followerId == request.auth.uid &&
                    followId == request.auth.uid + '_' + request.resource.data.followingId;
                    
      allow update: if isAuthenticated() && 
                    isValidFollow() &&
                    request.resource.data.followerId == request.auth.uid &&
                    followId == request.auth.uid + '_' + request.resource.data.followingId &&
                    areImmutableFieldsUnchanged(['followerId', 'followingId']);
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.followerId == request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidComment() &&
                    request.resource.data.authorId == request.auth.uid &&
                    (!('likesCount' in request.resource.data) || request.resource.data.likesCount == 0);
                    
      allow update: if isAuthenticated() && (
                      // Author updating text (if we wanted to allow editing)
                      (resource.data.authorId == request.auth.uid &&
                       isValidComment() &&
                       isUnchanged('postId') &&
                       isUnchanged('authorId') &&
                       isUnchanged('authorName') &&
                       isUnchanged('authorPhoto') &&
                       isUnchanged('createdAt') &&
                       isUnchanged('likesCount'))
                      ||
                      // Anyone updating likesCount
                      (isValidComment() &&
                       isUnchanged('postId') &&
                       isUnchanged('authorId') &&
                       isUnchanged('authorName') &&
                       isUnchanged('authorPhoto') &&
                       isUnchanged('text') &&
                       isUnchanged('createdAt') &&
                       (request.resource.data.get('likesCount', 0) - resource.data.get('likesCount', 0) == 1 || request.resource.data.get('likesCount', 0) - resource.data.get('likesCount', 0) == -1) &&
                       (
                         (request.resource.data.get('likesCount', 0) > resource.data.get('likesCount', 0) &&
                          !exists(/databases/$(database)/documents/commentLikes/$(commentId + '_' + request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/commentLikes/$(commentId + '_' + request.auth.uid)) != null) ||
                         (request.resource.data.get('likesCount', 0) < resource.data.get('likesCount', 0) &&
                          exists(/databases/$(database)/documents/commentLikes/$(commentId + '_' + request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/commentLikes/$(commentId + '_' + request.auth.uid)) == null)
                       )
                      )
                      ||
                      isAdmin()
                    );
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /commentLikes/{likeId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidCommentLike() &&
                    request.resource.data.userId == request.auth.uid &&
                    likeId == request.resource.data.commentId + '_' + request.auth.uid;
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isAuthenticated() && 
                    isValidNotification() &&
                    request.resource.data.senderId == request.auth.uid;
                    
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
                    request.resource.data.read == true;
                    
      allow delete: if isAuthenticated() && (
                      resource == null ||
                      resource.data.userId == request.auth.uid ||
                      resource.data.senderId == request.auth.uid ||
                      isAdmin()
                    );
    }

    match /savedPosts/{savedPostId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isAuthenticated() && 
                    isValidSavedPost() &&
                    request.resource.data.userId == request.auth.uid &&
                    savedPostId == request.auth.uid + '_' + request.resource.data.postId;
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /highlights/{highlightId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidHighlight() &&
                    request.resource.data.userId == request.auth.uid;
                    
      allow update: if isAuthenticated() && isValidHighlight() && (
                      // Owner updating highlight
                      (resource.data.userId == request.auth.uid &&
                       isUnchanged('userId') &&
                       isUnchanged('createdAt'))
                      ||
                      // Anyone updating views
                      (isUnchanged('userId') &&
                       isUnchanged('label') &&
                       isUnchanged('imageUrl') &&
                       isUnchanged('mediaUrls') &&
                       isUnchanged('createdAt') &&
                       request.resource.data.viewsCount == resource.data.get('viewsCount', 0) + 1 &&
                       request.resource.data.viewers.hasAll(resource.data.get('viewers', [])) &&
                       request.resource.data.viewers.hasAll([request.auth.uid]) &&
                       request.resource.data.viewers.size() == resource.data.get('viewers', []).size() + 1
                      )
                      ||
                      isAdmin()
                    );
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /stories/{storyId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidStory() &&
                    request.resource.data.authorId == request.auth.uid;
                    
      allow update: if isAuthenticated() && isValidStory() && (
                      // Views update
                      (isUnchanged('authorId') &&
                       isUnchanged('authorName') &&
                       isUnchanged('authorPhoto') &&
                       isUnchanged('imageUrl') &&
                       isUnchanged('createdAt') &&
                       isUnchanged('expiresAt') &&
                       isUnchanged('likesCount') &&
                       isUnchanged('likedBy') &&
                       request.resource.data.viewsCount == resource.data.get('viewsCount', 0) + 1 &&
                       request.resource.data.viewers.hasAll(resource.data.get('viewers', [])) &&
                       request.resource.data.viewers.hasAll([request.auth.uid]) &&
                       request.resource.data.viewers.size() == resource.data.get('viewers', []).size() + 1
                      )
                      ||
                      // Likes update
                      (isUnchanged('authorId') &&
                       isUnchanged('authorName') &&
                       isUnchanged('authorPhoto') &&
                       isUnchanged('imageUrl') &&
                       isUnchanged('createdAt') &&
                       isUnchanged('expiresAt') &&
                       isUnchanged('viewsCount') &&
                       isUnchanged('viewers') &&
                       (request.resource.data.get('likesCount', 0) - resource.data.get('likesCount', 0) == 1 || resource.data.get('likesCount', 0) - request.resource.data.get('likesCount', 0) == 1) &&
                       (
                         (request.resource.data.get('likesCount', 0) > resource.data.get('likesCount', 0) &&
                          !exists(/databases/$(database)/documents/storyLikes/$(storyId + '_' + request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/storyLikes/$(storyId + '_' + request.auth.uid)) != null &&
                          request.resource.data.likedBy.hasAll(resource.data.get('likedBy', [])) &&
                          request.resource.data.likedBy.hasAll([request.auth.uid]) &&
                          request.resource.data.likedBy.size() == resource.data.get('likedBy', []).size() + 1) ||
                         (request.resource.data.get('likesCount', 0) < resource.data.get('likesCount', 0) &&
                          exists(/databases/$(database)/documents/storyLikes/$(storyId + '_' + request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/storyLikes/$(storyId + '_' + request.auth.uid)) == null &&
                          resource.data.get('likedBy', []).hasAll(request.resource.data.likedBy) &&
                          !request.resource.data.likedBy.hasAny([request.auth.uid]) &&
                          request.resource.data.likedBy.size() == resource.data.get('likedBy', []).size() - 1)
                       )
                      )
                      ||
                      isAdmin()
                    );
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /storyLikes/{likeId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    isValidStoryLike() &&
                    request.resource.data.userId == request.auth.uid &&
                    likeId == request.resource.data.storyId + '_' + request.auth.uid;
                    
      allow delete: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      
      allow create: if isAuthenticated() && 
                    isValidChat() &&
                    request.auth.uid in request.resource.data.participants &&
                    !isEitherBlocked(request.resource.data.participants[0], request.resource.data.participants[1]);
                    
      allow update: if isAuthenticated() && 
                    (request.auth.uid in resource.data.participants || isAdmin()) &&
                    isValidChat() &&
                    request.resource.data.participants == resource.data.participants;
                    
      allow delete: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.participants || isAdmin());
                    
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
                      ((exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) || isAdmin());
        
        allow create: if isAuthenticated() && 
                      isValidMessage() &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.chatId == chatId &&
                      (
                        (exists(/databases/$(database)/documents/chats/$(chatId)) && 
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                         !isEitherBlocked(get(/databases/$(database)/documents/chats/$(chatId)).data.participants[0], get(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]))
                        ||
                        (existsAfter(/databases/$(database)/documents/chats/$(chatId)) && 
                         request.auth.uid in getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                         !isEitherBlocked(getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants[0], getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants[1]))
                      );

        allow update: if isAuthenticated() &&
                      isValidMessage() &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      (
                        (
                          resource.data.senderId == request.auth.uid &&
                          request.resource.data.senderId == request.auth.uid &&
                          request.time.toMillis() < resource.data.createdAt.toMillis() + 3600000 &&
                          isUnchanged('chatId') &&
                          isUnchanged('senderId') &&
                          isUnchanged('createdAt') &&
                          isUnchanged('attachmentUrl') &&
                          isUnchanged('sharedPostId') &&
                          isUnchanged('sharedPostSlideIndex') &&
                          isUnchanged('deletedFor')
                        )
                        ||
                        (
                          isUnchanged('chatId') &&
                          isUnchanged('senderId') &&
                          isUnchanged('text') &&
                          isUnchanged('attachmentUrl') &&
                          isUnchanged('sharedPostId') &&
                          isUnchanged('sharedPostSlideIndex') &&
                          isUnchanged('createdAt') &&
                          isUnchanged('editedAt') &&
                          isUnchanged('isEdited') &&
                          request.resource.data.deletedFor.hasAll(resource.data.get('deletedFor', [])) &&
                          request.resource.data.deletedFor.hasAll([request.auth.uid]) &&
                          (request.resource.data.deletedFor.size() == resource.data.get('deletedFor', []).size() + 1 || request.resource.data.deletedFor.size() == resource.data.get('deletedFor', []).size())
                        )
                      );

        allow delete: if isAuthenticated() && (
                          (resource.data.senderId == request.auth.uid && 
                           (!('createdAt' in resource.data) || resource.data.createdAt == null || request.time.toMillis() < resource.data.createdAt.toMillis() + 86400000)) || 
                          isAdmin()
                        );
      }
    }

    match /blocks/{blockId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.blockerId == request.auth.uid || resource.data.blockedId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBlock() && request.resource.data.blockerId == request.auth.uid && blockId == request.auth.uid + '_' + request.resource.data.blockedId;
      allow delete: if isAuthenticated() && (resource == null || resource.data.blockerId == request.auth.uid || isAdmin());
    }
  }
}
